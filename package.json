{
  "name": "dust-saga",
  "version": "1.0.0",
  "description": "Low poly 3D MMORPG with Babylon.js",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:client": "cd packages/client && npm run dev",
    "dev:server": "cd packages/server && npm run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@nx/workspace": "^22.6.5",
    "lerna": "^9.0.7",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "@types/node": "^25.6.0"
  },
  "dependencies": {
    "@babylonjs/core": "^9.2.0",
    "@babylonjs/gui": "^9.2.0",
    "@babylonjs/loaders": "^9.2.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.32"
  },
  "packageManager": "npm@11.12.1"
}
