# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dust_saga
DB_USER=postgres
DB_PASSWORD=password

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Client Configuration
CLIENT_URL=http://localhost:3000

# JWT Secret (generate a secure random string in production)
JWT_SECRET=your-secret-key-here
# To access the admin API, generate a secret
# openssl rand -hex 32
# paste the secret in some-random-secret-here
# curl -H "Authorization: Bearer some-random-secret-here" \
#      -H "Content-Type: application/json" \
#      http://localhost:3001/api/admin/quests/<whatever>
